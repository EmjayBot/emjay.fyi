---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Kainoa — Emjay',
  description: 'AI Assistant and Wayfinder search, built on Anoatech for Tep Worlds.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Kainoa</h1>
    <p class="text-xl text-muted mb-8">
      AI assistant and search, built exclusively for Tep Worlds — powered by Anoatech.
    </p>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>What it is</h2>
      <ul>
        <li><strong>Kainoa Assistant</strong> — context-aware help for worldbuilding, lore lookups, and writing</li>
        <li><strong>Wayfinder</strong> — semantic search across Tep Worlds content, not the open web</li>
      </ul>

      <h2>Built on Anoatech</h2>
      <p>
        Kainoa isn't a standalone app — it's the reference implementation of Anoatech. Everything runs on the same
        platform: auth, vector store, functions, and docs.
      </p>

      <h2>Access</h2>
      <p>Private beta for Tep Worlds contributors. Public docs coming with Anoatech v1.</p>
    </div>
  </section>
</Layout>
