---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Anoatech — Emjay',
  description: 'Tech experiments and prototypes.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Anoatech</h1>
    <p class="text-xl text-muted mb-8">R&D lab for weird ideas — AI tools, automation, and prototypes.</p>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>Current Experiments</h2>
      <ul>
        <li>AI-assisted writing workflows</li>
        <li>Browser automation tools</li>
        <li>Data visualization sketches</li>
      </ul>
    </div>
  </section>
</Layout>
