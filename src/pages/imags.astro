---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Ima.gs — Emjay',
  description: 'Fast image tools and experiments.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Ima.gs</h1>
    <p class="text-xl text-muted mb-8">
      Lightweight image utilities — resize, convert, optimize. Built for speed.
    </p>
    
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>What it does</h2>
      <ul>
        <li>Drag-and-drop image compression</li>
        <li>Format conversion (WebP, AVIF, PNG, JPG)</li>
        <li>Batch processing</li>
      </ul>
      
      <h2>Status</h2>
      <p>In development. Early access coming soon.</p>
    </div>
  </section>
</Layout>
