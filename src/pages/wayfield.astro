---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Wayfield Labs — Emjay',
  description: 'Research and tools from Wayfield Labs.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Wayfield Labs</h1>
    <p class="text-xl text-muted mb-8">
      Research, prototypes, and tools. Home base: <a href="https://wayfield.dev" class="text-primary hover:underline"
        >wayfield.dev</a
      >
    </p>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>Focus</h2>
      <p>
        Wayfield Labs is where I build in public. Think small, sharp experiments that support the bigger worldbuilding
        work on Urth.
      </p>
      <ul>
        <li>Semantic search and navigation tools</li>
        <li>Language and writing utilities</li>
        <li>Open datasets for fictional worlds</li>
      </ul>

      <h2>Relationship to Worldbuilding</h2>
      <p>Everything at Wayfield feeds back into the Free Pax States and Kilumi. Tools first, then worlds.</p>
    </div>
  </section>
</Layout>
