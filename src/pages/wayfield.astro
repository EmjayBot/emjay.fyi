---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Wayfield Labs — Emjay',
  description: 'Git-native software for communities the tech industry ignores.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Wayfield Labs</h1>
    <p class="text-xl text-muted mb-8">
      Git-native software for communities the tech industry ignores.
      <a href="https://wayfield.dev" class="text-primary hover:underline">wayfield.dev →</a>
    </p>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>20 open-source apps. 4 categories. 1 mission.</h2>
      <ul>
        <li><strong>Infra</strong> — host your own, no vendor lock-in</li>
        <li><strong>Communication</strong> — tools that work without the cloud</li>
        <li><strong>Data</strong> — own your records, sync via git</li>
        <li><strong>Business</strong> — boring, essential software for small orgs</li>
      </ul>

      <p>All MIT licensed. All offline-capable. All yours.</p>

      <p><em>Separate from my worldbuilding work on Urth.</em></p>
    </div>
  </section>
</Layout>
