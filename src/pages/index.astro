---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Emjay — Worldbuilder & Conlanger',
  description: 'Portfolio of worldbuilding, Ima.gs, Kainoa Apps, and Anoatech documentation.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <Hero
    actions={[
      { variant: 'primary', text: 'View Portfolio', href: '#portfolio' },
      { text: 'About', href: '/about' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Emjay worldbuilding' }}
  >
    <Fragment slot="title">
      Hi! I'm <span class="text-accent dark:text-white highlight">Emjay</span>!
    </Fragment>

    <Fragment slot="subtitle">
      I world-build and conlang. I create languages, cultures, maps, and stories — and build the tools to support them.
    </Fragment>
  </Hero>

  <!-- PORTFOLIO -->
  <Features2
    id="portfolio"
    title="Portfolio"
    subtitle="Four tracks of work"
    columns={2}
    items={[
      {
        title: 'Worldbuilding',
        description: 'My personal worlds, maps, cultures, and conlangs — the creative foundation.',
        icon: 'tabler:world',
        callToAction: { text: 'Explore →', href: '/worldbuilding' },
      },
      {
        title: 'Ima.gs',
        description: 'Image tools, experiments, and lightweight hosting utilities.',
        icon: 'tabler:photo',
        callToAction: { text: 'Visit Ima.gs →', href: '/imags' },
      },
      {
        title: 'Kainoa Apps',
        description: 'Apps and utilities built under the Kainoa brand for creators and communities.',
        icon: 'tabler:apps',
        callToAction: { text: 'See apps →', href: '/kainoa' },
      },
      {
        title: 'Anoatech',
        description: 'Public documentation and releases for the apps I ship.',
        icon: 'tabler:book-2',
        callToAction: { text: 'Read docs →', href: '/anoatech' },
      },
    ]}
  />
</Layout>
