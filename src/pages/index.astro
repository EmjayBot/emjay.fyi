---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Emjay — Worldbuilder & Conlanger',
  description: 'Portfolio of worldbuilding, Ima.gs, Kainoa Apps, and Anoatech documentation.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Explore Worldbuilding',
        href: '/worldbuilding',
        icon: 'tabler:map',
      },
      { text: 'Wayfield Labs', href: 'https://wayfield.dev' },
    ]}
  >
    <Fragment slot="title">
      Worldbuilding on <span class="text-accent dark:text-white highlight">Urth</span> +
      <br class="hidden md:block" />
      <span>open-source for everyone else</span>
    </Fragment>

    <Fragment slot="subtitle">
      I'm Emjay — I collaborate on <strong>Urth</strong>, including the <strong>Free Pax States</strong> and <strong
        >Kilumi</strong
      > conlang. I also run <strong>Wayfield Labs</strong>: git-native software for communities the tech industry
      ignores. 20 open-source apps. 4 categories. 1 mission.
    </Fragment>
  </Hero>
  <!-- PORTFOLIO -->
</Layout>
