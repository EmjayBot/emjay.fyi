---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Emjay — Worldbuilder & Conlanger',
  description: 'Portfolio of worldbuilding, Ima.gs, Kainoa Apps, and Anoatech documentation.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
 <Hero
  actions={[
    {
      variant: 'primary',
      text: 'Explore Worldbuilding',
      href: '/worldbuilding',
      icon: 'tabler:map',
    },
    { text: 'Wayfield Labs', href: 'https://wayfield.dev' },
  ]}
>
  <Fragment slot="title">
    Worldbuilding on <span class="text-accent dark:text-white highlight">Urth</span> + 
    <br class="hidden md:block" />
    <span>open-source for everyone else</span>
  </Fragment>

  <Fragment slot="subtitle">
    I'm Emjay — I collaborate on <strong>Urth</strong>, including the <strong>Free Pax States</strong> and <strong>Kilumi</strong> conlang. 
    I also run <strong>Wayfield Labs</strong>: git-native software for communities the tech industry ignores. 
    20 open-source apps. 4 categories. 1 mission.
  </Fragment>
</Hero>
  <!-- PORTFOLIO -->
  <Features2
    id="portfolio"
    title="Portfolio"
    subtitle="Four tracks of work"
    columns={2}
    items={[
      {
        title: 'Worldbuilding',
        description: 'My personal worlds, maps, cultures, and conlangs — the creative foundation.',
        icon: 'tabler:world',
        callToAction: { text: 'Explore →', href: '/worldbuilding' },
      },
      {
        title: 'Ima.gs',
        description: 'Image tools, experiments, and lightweight hosting utilities.',
        icon: 'tabler:photo',
        callToAction: { text: 'Visit Ima.gs →', href: '/imags' },
      },
      {
        title: 'Kainoa Apps',
        description: 'Apps and utilities built under the Kainoa brand for creators and communities.',
        icon: 'tabler:apps',
        callToAction: { text: 'See apps →', href: '/kainoa' },
      },
      {
        title: 'Anoatech',
        description: 'Public documentation and releases for the apps I ship.',
        icon: 'tabler:book-2',
        callToAction: { text: 'Read docs →', href: '/anoatech' },
      },
    ]}
  />
</Layout>
