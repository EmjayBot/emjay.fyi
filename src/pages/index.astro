---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Emjay — Worldbuilder & Conlanger',
  description: 'Portfolio of worldbuilding, Ima.gs, Kainoa Apps, and Anoatech documentation.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Explore Worldbuilding',
        href: '/worldbuilding',
        icon: 'tabler:map',
      },
      { text: 'Wayfield Labs', href: 'https://wayfield.dev' },
    ]}
  >
    <Fragment slot="title">
      Worldbuilding on <span class="text-accent dark:text-white highlight">Urth</span> +
      <br class="hidden md:block" />
      <span>open-source for everyone else</span>
    </Fragment>

    <Fragment slot="subtitle">
      I'm Emjay — I collaborate on <strong>Urth</strong>, including the <strong>Free Pax States</strong> and <strong
        >Kilumi</strong
      > conlang. I also run <strong>Wayfield Labs</strong>: git-native software for communities the tech industry
      ignores. 20 open-source apps. 4 categories. 1 mission.
    </Fragment>
  </Hero>
  <!-- PORTFOLIO -->
<Features
  id="portfolio"
  title="Current Projects"
  subtitle="Two tracks: collaborative worldbuilding, and open-source infrastructure."
  columns={2}
  items={[
    {
      title: 'Urth Worldbuilding',
      description:
        'Collaborative worldbuilding project. Home to the Free Pax States and the Kilumi conlang. Active since 2006.',
      icon: 'tabler:world',
      callToAction: {
        text: 'Explore Urth',
        href: '/worldbuilding',
      },
    },
    {
      title: 'Wayfield Labs',
      description:
        'Git-native software for communities the tech industry ignores. 20 open-source apps across Infra, Communication, Data, and Business. All MIT, offline-capable.',
      icon: 'tabler:git-branch',
      callToAction: {
        text: 'wayfield.dev →',
        href: 'https://wayfield.dev',
        target: '_blank',
      },
    },
  ]}
/>
</Layout>
